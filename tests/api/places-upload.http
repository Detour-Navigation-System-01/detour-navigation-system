### 画像アップロードテスト（JWT認証が必要）
@baseUrl = http://localhost:3001/api

// ログイン後に取得したJWTトークンを保存するための変数
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NSwidXNlcm5hbWUiOiJuYWthbmlzaGkzIiwiaWF0IjoxNzUxNTkyNDkwLCJleHAiOjE3NTE1OTYwOTB9.sdtTSwLaZzUzcLMZkshDumZCW27FDhsyv8DmnJ77NHU

# multipart/form-dataを使ってファイルをアップロード
# VS CodeのREST Clientプラグインでは以下のように記述することでファイルをアップロードできます
# ※以下の <実際の画像パス> を実在する画像ファイルのパスに変更してください
# 例: < C:/Users/YourName/Pictures/sample.jpg
# 注意: サイズ制限は10MBまでです

POST {{baseUrl}}/places/upload-image
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW
Authorization: Bearer {{authToken}}

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="image"; filename="sample.jpg"
Content-Type: image/jpeg

< C:\Users\Yonosuke\Pictures\Screenshots\スクリーンショット 2025-06-22 120309.png
------WebKitFormBoundary7MA4YWxkTrZu0gW--

### アップロード後に場所を作成（画像URL付き）- JWT認証が必要
POST {{baseUrl}}/places
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "東京タワー2",
  "description": "東京のランドマーク",
  "category": "観光地",
  "address": "東京都港区芝公園4丁目2-8",
  "prefecture": "東京都",
  "lat": 35.6586,
  "lng": 139.7454,
  "image_url": "http://localhost:3001/images/image-1750749368343-774252979.png"
}

### アップロード後に場所を作成（画像URL付き）2 - JWT認証が必要
POST {{baseUrl}}/places
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "芝浦公園",
  "description": "東京のランドマーク",
  "category": "観光地",
  "address": "東京都港区芝公園4丁目2-8",
  "prefecture": "東京都",
  "lat": 35.6586,
  "lng": 139.7454,
  "image_url": "http://localhost:3001/images/image-1750750114063-247358797.png"
}

### 画像付き場所の取得
GET http://localhost:3001/api/places/7
Accept: application/json
