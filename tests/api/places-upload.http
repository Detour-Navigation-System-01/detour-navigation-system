### 画像アップロードテスト（JWT認証が必要）
@baseUrl = http://localhost:3001/api

// ログイン後に取得したJWTトークンを保存するための変数
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywidXNlcm5hbWUiOiJuYWthbmlzaGkxIiwiaWF0IjoxNzUxMTkxNjE3LCJleHAiOjE3NTExOTUyMTd9.77Aah85j0izBRsWX3CPAk2cdmsAT-ICfh9zHwUNEDwk

# multipart/form-dataを使ってファイルをアップロード
# VS CodeのREST Clientプラグインでは以下のように記述することでファイルをアップロードできます
# ※実際のファイルのパスに変更してください

POST {{baseUrl}}/places/upload-image
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW
Authorization: Bearer {{authToken}}

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="image"; filename="sample.jpg"
Content-Type: image/jpeg

< ./path/to/your/sample.jpg
------WebKitFormBoundary7MA4YWxkTrZu0gW--

### アップロード後に場所を作成（画像URL付き）- JWT認証が必要
POST {{baseUrl}}/places
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "東京タワー2",
  "description": "東京のランドマーク",
  "category": "観光地",
  "address": "東京都港区芝公園4丁目2-8",
  "prefecture": "東京都",
  "lat": 35.6586,
  "lng": 139.7454,
  "image_url": "http://localhost:3001/images/image-1750749368343-774252979.png"
}

### アップロード後に場所を作成（画像URL付き）2 - JWT認証が必要
POST {{baseUrl}}/places
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "芝浦公園",
  "description": "東京のランドマーク",
  "category": "観光地",
  "address": "東京都港区芝公園4丁目2-8",
  "prefecture": "東京都",
  "lat": 35.6586,
  "lng": 139.7454,
  "image_url": "http://localhost:3001/images/image-1750750114063-247358797.png"
}

### 画像付き場所の取得
GET http://localhost:3001/api/places/7
Accept: application/json
