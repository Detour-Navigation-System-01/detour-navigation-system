# 経路計算API呼び出しテストファイル
@baseUrl = http://localhost:3001/api
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywidXNlcm5hbWUiOiJuYWthbmlzaGkyIiwiaWF0IjoxNzUxMzQwNTA3LCJleHAiOjE3NTEzNDQxMDd9.nLoeO65fK9MHUuFI02RSRMzUDmZAyDrpKK5Cr8WkMsc

### 接続テスト - デフォルト（東京駅→皇居）
GET {{baseUrl}}/routes/test
Content-Type: application/json

### 経路計算 - 東京駅から皇居
POST {{baseUrl}}/routes/calculate
Content-Type: application/json

{
  "origin": {
    "lat": 35.6812,
    "lng": 139.7671
  },
  "destination": {
    "lat": 35.6853,
    "lng": 139.7528
  },
  "profile": "driving",
  "includeSteps": true
}

### 経路計算 - 東京駅から浅草
POST {{baseUrl}}/routes/calculate
Content-Type: application/json

{
  "origin": {
    "lat": 35.6812,
    "lng": 139.7671
  },
  "destination": {
    "lat": 35.7147,
    "lng": 139.7967
  },
  "profile": "driving",
  "includeSteps": true
}

### 経路計算 - 経由地点あり（渋谷→新宿→上野）
POST {{baseUrl}}/routes/calculate
Content-Type: application/json

{
  "origin": {
    "lat": 35.6580,
    "lng": 139.7016
  },
  "destination": {
    "lat": 35.7140,
    "lng": 139.7767
  },
  "waypoints": [
    {
      "lat": 35.6938,
      "lng": 139.7034
    }
  ],
  "profile": "driving",
  "includeSteps": true
}

### 経路計算 - 移動手段を指定（徒歩）
POST {{baseUrl}}/routes/calculate
Content-Type: application/json

{
  "origin": {
    "lat": 35.6812,
    "lng": 139.7671
  },
  "destination": {
    "lat": 35.6853,
    "lng": 139.7528
  },
  "profile": "walking",
  "includeSteps": true
}

### 経路計算 - 代替経路を取得
POST {{baseUrl}}/routes/calculate-alternatives
Content-Type: application/json

{
  "origin": {
    "lat": 35.6812,
    "lng": 139.7671
  },
  "destination": {
    "lat": 35.6853,
    "lng": 139.7528
  },
  "numAlternatives": 2,
  "profile": "driving"
}

### RouteService - 経路計算して保存（JWT認証が必要）
POST {{baseUrl}}/routes/save
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "新しい経路",
  "description": "テスト用ルート",
  "origin": {
    "lat": 35.6812,
    "lng": 139.7671
  },
  "destination": {
    "lat": 35.6853,
    "lng": 139.7528
  },
  "profile": "walking",
  "requestedDuration": 10000
}

### RouteService - 経路計算して保存2（JWT認証が必要）
POST {{baseUrl}}/routes/save
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "越中島駅から豊洲キャンパスへのルート2",
  "description": "テスト用ルート",
  "origin": {
    "lat": 35.667953356386896,
    "lng": 139.79265406072273
  },
  "destination": {
    "lat": 35.66069879583367,
    "lng": 139.79480768096218
  },
  "profile": "walking",
  "requestedDuration": 1200
}

### RouteService - 代替経路を計算
POST {{baseUrl}}/routes/alternatives
Content-Type: application/json

{
  "origin": {
    "lat": 35.68125,
    "lng": 139.76715
  },
  "destination": {
    "lat": 35.68535,
    "lng": 139.75285
  },
  "numAlternatives": 3,
  "profile": "driving",
  "userId": 1
}

### RouteService - 経路詳細を取得（ID指定）（JWT認証が必要）
GET {{baseUrl}}/routes/2
Content-Type: application/json
Authorization: Bearer {{authToken}}

### RouteService - 経路履歴を取得（認証済みユーザー向け）
GET {{baseUrl}}/routes/history
Content-Type: application/json
Authorization: Bearer {{authToken}}

### RouteService - 所要時間が短すぎる場合のエラーテスト（JWT認証が必要）
POST {{baseUrl}}/routes/save
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "所要時間が短すぎる経路",
  "description": "最短経路より短い所要時間を指定するとエラーになるはず",
  "origin": {
    "lat": 35.6812,
    "lng": 139.7671
  },
  "destination": {
    "lat": 35.6853,
    "lng": 139.7528
  },
  "profile": "walking",
  "requestedDuration": 1000
}

# 注: ログイン後に取得したJWTトークンを上部の @authToken 変数に設定してください
