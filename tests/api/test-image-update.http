### レスポンスからトークンをコピーして上の@authTokenに貼り付けてください

### 新しい画像付きスポット1を作成
POST {{baseUrl}}/places
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "画像テストスポット1",
  "description": "実際の画像ファイルを使ったテストスポット",
  "category": "テスト",
  "address": "東京都渋谷区神宮前",
  "prefecture": "東京都",
  "lat": 35.6580,
  "lng": 139.7016,
  "image_url": "http://localhost:3001/images/image-1750842092056-99036958.jpg"
}

