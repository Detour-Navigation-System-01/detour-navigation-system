# データベース接続設定
# Docker環境内でアプリを実行する場合は DB_HOST=db
# ローカルマシン上で直接実行する場合は DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=wanderdb

# サーバー設定
PORT=3001
NODE_ENV=development

# 外部API設定
OSRM_API_URL=http://router.project-osrm.org

JWT_SECRET=your-very-secret-key